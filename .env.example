# kanban-mcp database configuration
#
# Backend: "sqlite" (default, zero-config) or "mysql"
# If KANBAN_BACKEND is not set, auto-detected:
#   - MySQL if KANBAN_DB_USER, KANBAN_DB_PASSWORD, and KANBAN_DB_NAME are all set
#   - SQLite otherwise
# KANBAN_BACKEND=sqlite

# === SQLite options ===
# Path to SQLite database file (default: ~/.local/share/kanban-mcp/kanban.db)
# Respects XDG_DATA_HOME
# KANBAN_SQLITE_PATH=/path/to/kanban.db

# === MySQL/MariaDB options ===
# Required when using MySQL backend:
# KANBAN_DB_HOST=localhost
# KANBAN_DB_USER=kanban
# KANBAN_DB_PASSWORD=changeme
# KANBAN_DB_NAME=kanban
# KANBAN_DB_PORT=3306

# Project directory (optional - usually set by MCP config)
# KANBAN_PROJECT_DIR=/path/to/your/project
